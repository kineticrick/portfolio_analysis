# Copy this file to `.env` and fill in your key. The Chat tab reads
# ANTHROPIC_API_KEY from here (loaded by libraries/chat/config.py via python-dotenv).
# A real `.env` is gitignored and must never be committed.
#
# An ANTHROPIC_API_KEY exported in your shell takes precedence over this file.
ANTHROPIC_API_KEY=sk-ant-your-key-here
